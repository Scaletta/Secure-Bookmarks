{
  "manifest_version": 3,
  "name": "Secure Bookmarks",
  "version": "1.0.0",
  "description": "Password-protected encrypted bookmark manager. Bookmarks are AES-256-GCM encrypted and only visible after entering your master password.",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "index.html",
    "default_title": "Secure Bookmarks",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
